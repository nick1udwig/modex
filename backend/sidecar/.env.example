MODEX_SIDECAR_ADDR=:4230
MODEX_SIDECAR_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MODEX_SIDECAR_AUTH_TOKEN=
MODEX_SIDECAR_LOG_LEVEL=warn

# Optional filesystem restriction. Empty means unrestricted.
MODEX_FS_ROOTS=
# Alias also accepted: MODEX_SIDECAR_FS_ROOTS
MODEX_FS_INCLUDE_HIDDEN=false
MODEX_FS_SEARCH_MAX_RESULTS=100

# Required for transcription proxying.
OPENAI_API_KEY=sk-...
MODEX_TRANSCRIPTION_UPSTREAM_URL=wss://api.openai.com/v1/realtime?intent=transcription
# Alias also accepted: MODEX_SIDECAR_OPENAI_REALTIME_URL
MODEX_TRANSCRIPTION_MODEL=gpt-4o-transcribe
MODEX_TRANSCRIPTION_INPUT_AUDIO_FORMAT=pcm16
MODEX_TRANSCRIPTION_LANGUAGE=
MODEX_TRANSCRIPTION_PROMPT=
MODEX_TRANSCRIPTION_NOISE_REDUCTION=near_field
MODEX_TRANSCRIPTION_VAD=true
MODEX_TRANSCRIPTION_VAD_THRESHOLD=0.5
MODEX_TRANSCRIPTION_PREFIX_PADDING_MS=300
MODEX_TRANSCRIPTION_SILENCE_DURATION_MS=500
MODEX_TRANSCRIPTION_INCLUDE=item.input_audio_transcription.logprobs
